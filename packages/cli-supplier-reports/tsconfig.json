{
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "isolatedModules": true,
    "module": "commonjs",
    "outDir": "dist",
    "paths": {
      "@supplier-config/excel-parser": [
        "../excel-parser/src/index.ts"
      ],
      "@supplier-config/excel-parser/*": [
        "../excel-parser/src/*"
      ]
    },
    "resolveJsonModule": true,
    "rootDir": "src"
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*"
  ],
  "references": [
    {
      "path": "../excel-parser"
    }
  ],
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ]
  }
}
