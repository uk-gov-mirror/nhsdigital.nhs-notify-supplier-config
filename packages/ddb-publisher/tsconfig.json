{
  "compilerOptions": {
    "declaration": true,
    "isolatedModules": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": "src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "exclude": [
    "dist",
    "node_modules"
  ],
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*.ts"
  ]
}
