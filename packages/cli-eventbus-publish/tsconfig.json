{
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "commonjs",
    "outDir": "dist",
    "paths": {
      "@supplier-config/event-builder": [
        "../event-builder/src/index.ts"
      ],
      "@supplier-config/event-builder/*": [
        "../event-builder/src/*"
      ],
      "@supplier-config/excel-parser": [
        "../excel-parser/src/index.ts"
      ],
      "@supplier-config/excel-parser/*": [
        "../excel-parser/src/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__"
  ],
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*"
  ]
}
